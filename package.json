{
  "name": "realdeal-grocery-comparison",
  "version": "1.0.0",
  "description": "Smart Grocery Price Comparison Platform - Compare prices across Blinkit, Zepto, Instamart, and BigBasket",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm --prefix client start",
    "build": "npm --prefix client run build",
    "start": "node server/index.js",
    "install-all": "npm install && cd client && npm install",
    "scrape": "node server/scripts/scrape-on-demand.js",
    "seed": "node server/scripts/seed.js",
    "seed:advanced": "node server/scripts/advancedSeed.js"
  },
  "keywords": [
    "grocery",
    "price-comparison",
    "blinkit",
    "zepto",
    "instamart",
    "bigbasket",
    "quick-commerce",
    "e-commerce"
  ],
  "author": "RealDeal Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "puppeteer": "^21.1.1",
    "rate-limiter-flexible": "^2.4.2",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
