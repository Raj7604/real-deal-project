# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/realdeal

# Scraping Configuration
SCRAPING_INTERVAL_HIGH=15
SCRAPING_INTERVAL_MEDIUM=60
SCRAPING_INTERVAL_LOW=240

# Location Configuration
